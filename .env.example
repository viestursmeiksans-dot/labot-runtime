# Copy to .env on the VPS (chmod 600). Loaded by the systemd unit / your shell.
# Anthropic API key — the Agent SDK reads this for the edit sessions.
ANTHROPIC_API_KEY="sk-ant-..."
# Fine-grained GitHub PAT with Contents: Read & write on the site repos (clone + push).
GITHUB_TOKEN="github_pat_..."
# Where site checkouts live (default /srv/sites).
LABOT_SITES_DIR="/srv/sites"
